# Runtime environment selector:
# - dev  -> uses DEV_BOT_TOKEN + DEV_DB_URL (if TELEGRAM_TOKEN/DATABASE_URL are empty)
# - prod -> uses PROD_BOT_TOKEN + PROD_DB_URL (if TELEGRAM_TOKEN/DATABASE_URL are empty)
APP_ENV=dev

# Dev/Prod explicit pairs (recommended for safe switching)
# DSN format example: postgresql+psycopg2://user:password@host:5432/dbname
DEV_BOT_TOKEN=
DEV_DB_URL=
PROD_BOT_TOKEN=
PROD_DB_URL=

# Legacy direct values (kept for backward compatibility)
# If set, these override DEV_*/PROD_* values above.
# Example: DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/event_bot
DATABASE_URL=

# Telegram Bot
TELEGRAM_TOKEN=
# Одноразовая рассылка «переехали» со старого бота: scripts/broadcast_old_bot_moved.py
# OLD_TELEGRAM_TOKEN=...
# NEW_BOT_USERNAME=@MyGuide_EventBot

# Telegram event ingestion (userbot worker + moderation)
# TELEGRAM_INGEST_ENABLED=0
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_STRING_SESSION=
# MODERATION_CHAT_ID=
# INTERNAL_INGEST_SECRET=
# API_BASE_URL=https://your-app.up.railway.app

# Meetup (опционально, по умолчанию отключено)
MEETUP_ENABLED=0
# MEETUP_MOCK=0
# MEETUP_CLIENT_ID=
# MEETUP_CLIENT_SECRET=
# MEETUP_REDIRECT_URI=http://localhost:8000/oauth/meetup/callback

# После обмена кода на токены пользователь вручную добавит эти значения:
# MEETUP_ACCESS_TOKEN=
# MEETUP_REFRESH_TOKEN=

# Meetup API (legacy, если используется)
# MEETUP_API_KEY=your_meetup_api_key_here

# Other APIs
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Ingest scheduler
INGEST_DEFAULT_FREQ_MIN=120
INGEST_MAX_FAILS=5

# Geo bounds settings (по умолчанию все выключено)
ENABLE_GEO_BOUNDS=false
RUSSIA_BOUNDS_ENABLED=false

# KudaGo source settings (по умолчанию все выключено)
KUDAGO_ENABLED=false
KUDAGO_DRY_RUN=true
KUDAGO_RPS=3
KUDAGO_TIMEOUT_S=8
KUDAGO_PAGE_SIZE=100
TODAY_MAX_EVENTS=400
TODAY_SHOW_TOP=12
CACHE_TTL_S=300

